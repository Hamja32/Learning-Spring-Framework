<!-- Constructor based Dependency Injection -->
	<bean class="com.xmlconfig.beans.Address" id="add1">
		<constructor-arg value="101"></constructor-arg>
		<constructor-arg
			value="Dev Nagar Rajeev Gandhi Colony"></constructor-arg>
		<constructor-arg value="105">
		</constructor-arg>
		<constructor-arg value="342008"></constructor-arg>
		<constructor-arg value="Jaipur"></constructor-arg>
		<constructor-arg value="Rajasthan"> </constructor-arg>
	</bean>
	
	<bean class="com.xmlconfig.beans.Student" id="std1">
		<constructor-arg value="991"></constructor-arg>
		<constructor-arg
			value="Yash"></constructor-arg>
		<constructor-arg value="yashpratp@gmail.com">
		</constructor-arg>
		<constructor-arg ref="add1"></constructor-arg>	
	</bean>
